DEBUG=True
SECRET_KEY=change-this-secret-key
DJANGO_ENV=local
ENABLE_HTTPS=False
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
CSRF_TRUSTED_ORIGINS=

# SQLite is used when DATABASE_URL and POSTGRES_DB are empty.
# Use one of the PostgreSQL configurations below when the database exists.

# Option 1: single URL
DATABASE_URL=postgresql://plataforma_user:plataforma_password@localhost:5432/plataforma_transito

# Option 2: separate variables
# POSTGRES_DB=plataforma_transito
# POSTGRES_USER=plataforma_user
# POSTGRES_PASSWORD=plataforma_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Production example:
# DJANGO_ENV=production
# DEBUG=False
# ENABLE_HTTPS=True
# SECRET_KEY=replace-with-a-long-random-secret-key
# ALLOWED_HOSTS=virval.cl,www.virval.cl
# CSRF_TRUSTED_ORIGINS=https://virval.cl,https://www.virval.cl
# DATABASE_URL=postgresql://plataforma_user:plataforma_password@db-host:5432/plataforma_transito
# SECURE_HSTS_SECONDS=31536000
